<Window x:Class="Podgotovka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Podgotovka"
        mc:Ignorable="d"
        Style="{StaticResource Windows}"
        Title="ООО «Обувь»" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#7FFF00">
            <Image Source="/Res/Icon.png" Margin="5" HorizontalAlignment="Left"/>
            <TextBlock Text="Магазин обуви" Margin="56,14,-46,-4" FontSize="20"/>
            <TextBlock Name="CurrentPage" Text="" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Name="UserOn" Text ="Гость" HorizontalAlignment="Right" Margin="0,18,50,-18"/>
            <Button Name="BackButton" Content="Назад" Margin="5" HorizontalAlignment="Right" Click="BackButton_Click"/>
        </Grid>

        <Frame Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
