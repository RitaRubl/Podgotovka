<Page x:Class="Podgotovka.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Podgotovka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Авторизация" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Логин  " Margin="5"/>
                <TextBox Name="LoginTxt" Margin="5" Width="150" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Пароль" Margin="5"/>
                <PasswordBox Name="PasswordTxt" Margin="5" Width="150" />
            </StackPanel>
            <Button Name="LoginBtn" Content="Войти" Click="LoginBtn_Click"/>
            <TextBlock Text="Войти как гость" MouseDown="GuestEnter_Click" Foreground="Blue" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
