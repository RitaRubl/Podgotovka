<Page x:Class="Podgotovka.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddEditProductPage">

    <Grid>
        <StackPanel Width="450"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="Добавление / редактирование"
                       FontSize="18"
                       Margin="0 0 0 15"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Название *"/>
            <TextBox x:Name="NameBox" Margin="0 5"/>

            <TextBlock Text="Артикул *"/>
            <TextBox x:Name="ArticleBox" Margin="0 5"/>

            <TextBlock Text="Описание *"/>
            <TextBox x:Name="DescriptionBox" Margin="0 5"
                     AcceptsReturn="True" Height="80"/>

            <TextBlock Text="Цена *"/>
            <TextBox x:Name="PriceBox" Margin="0 5"/>

            <TextBlock Text="Скидка (%)"/>
            <TextBox x:Name="DiscountBox" Margin="0 5"/>

            <TextBlock Text="Количество"/>
            <TextBox x:Name="AmountBox" Margin="0 5"/>

            <TextBlock Text="Фото"/>
            <TextBox x:Name="PhotoBox" Margin="0 5"/>

            <TextBlock Text="Единица"/>
            <TextBox x:Name="UnitBox" Margin="0 5"/>

            <TextBlock Text="Производитель"/>
            <ComboBox x:Name="ProducerBox"
                      ItemsSource="{Binding Producers}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      Margin="0 5"/>

            <TextBlock Text="Поставщик"/>
            <ComboBox x:Name="ProviderBox"
                      ItemsSource="{Binding Providers}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      Margin="0 5"/>

            <TextBlock Text="Категория"/>
            <ComboBox x:Name="CategoryBox"
                      ItemsSource="{Binding Categories}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      Margin="0 5"/>

            <Button Content="Сохранить"
                    Margin="0 20 0 0"
                    Padding="10"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Page>