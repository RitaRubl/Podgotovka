<Page x:Class="Podgotovka.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Podgotovka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Name="SearchingPanel"  Orientation="Horizontal" Grid.Row="0">
            
            <TextBlock Text="Поиск:" Margin="3"/>
            <TextBox Name="SearchTxt" Width="200" Margin="3" TextChanged="SearchTxt_TextChanged"/>
            
            <TextBlock Text="Сортировка:" Margin="3"/>
            <ComboBox Name="SortCmb" 
                      Width="100" 
                      Margin="3" 
                      SelectedIndex="0" 
                      SelectionChanged="SortCmb_SelectionChanged">
                <ComboBoxItem>По умолчанию</ComboBoxItem>
                <ComboBoxItem>По возрастанию</ComboBoxItem>
                <ComboBoxItem>По убыванию</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Фильтрация:" Margin="3"/>
            <ComboBox Name="FilterCmb" 
                      Width="100" 
                      Margin="3" 
                      SelectedItem="0" 
                      DisplayMemberPath="Name"
                      SelectionChanged="FilterCmb_SelectionChanged">
            </ComboBox>
        </StackPanel>

        <ListBox Name="ProductList" Grid.Row="1" HorizontalContentAlignment="Stretch" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0"
                               Width="100"
                               Height="100"
                               Stretch="Uniform"
                               Source="{Binding Photo}">
                        </Image>

                        <StackPanel Grid.Column="1" Margin="5 10">
                            <TextBlock>
                                <Run Text="{Binding Category.Name}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Описание товара: "/>
                                <Run Text="{Binding Description}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Производитель: "/>
                                <Run Text="{Binding Producer.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Поставщик: "/>
                                <Run Text="{Binding Provider.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Цена: "/>
                                <Run Text="{Binding Price}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Единица измерения: "/>
                                <Run Text="{Binding Unit.Name}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Количество на складе: "/>
                                <Run Text="{Binding AmountInStock}"/>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="{Binding Discount}" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOver15}" Value="True">
                            <Setter Property="Background" Value="#2E8B57"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel x:Name="ButtonsFullPanel" Grid.Row="2">
            <StackPanel x:Name="EditButtonsPanel">
                <Button x:Name="AddProductButton" Content="Добавить" Click="AddProductButton_Click"/>
                <Button x:Name="EditProductButton" Content="Редактировать" Click="EditProductButton_Click"/>
                <Button x:Name="DeleteProductButton" Content="Удалить" Click="DeleteProductButton_Click"/>
            </StackPanel>
            <Button x:Name="OrdersButton" 
            Content="Заказы" Click="OrdersButton_Click"/>
        </StackPanel>

    </Grid>
</Page>
